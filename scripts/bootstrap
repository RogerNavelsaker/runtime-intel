#!/usr/bin/env bash
set -euo pipefail

owner="${WORKSPACE_OWNER:-RogerNavelsaker}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
workspace_root="${SHARED_WORKSPACE_ROOT:-$repo_root}"

repos=(
  code-intel-rust
  code-intel-ts
  context-mode-cli
  context-mode-mcp
  nixos-cli
  pi-context-mode
  pi-os-eco
  repo-map
)

if ! command -v gh >/dev/null 2>&1; then
  echo "gh is required for bootstrap" >&2
  exit 1
fi

for repo in "${repos[@]}"; do
  target="$workspace_root/$repo"
  if [ -d "$target/.git" ]; then
    echo "present: $repo"
    continue
  fi

  echo "cloning: $owner/$repo -> $target"
  gh repo clone "$owner/$repo" "$target"
done

echo
echo "workspace ready at $workspace_root"
