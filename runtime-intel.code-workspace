{
  "folders": [
    {
      "name": "@runtime-intel",
      "path": "."
    },
    {
      "name": "nixpkg-code-intel-ts",
      "path": "./nixpkg-code-intel-ts"
    },
    {
      "name": "nixpkg-code-intel-rust",
      "path": "./nixpkg-code-intel-rust"
    },
    {
      "name": "nixpkg-repo-map",
      "path": "./nixpkg-repo-map"
    },
    {
      "name": "pi-os-eco",
      "path": "./pi-os-eco"
    }
  ],
  "settings": {
    "files.exclude": {
      "**/.direnv": true,
      "**/.flox": true
    },
    "files.watcherExclude": {
      "**/.direnv/**": true,
      "**/.flox/**": true
    },
    "search.exclude": {
      "**/.direnv": true,
      "**/.flox": true
    },
    "git.detectSubmodules": false
  },
  "extensions": {
    "recommendations": [
      "mkhl.direnv",
      "rust-lang.rust-analyzer",
      "biomejs.biome",
      "github.vscode-github-actions",
      "github.vscode-pull-request-github"
    ]
  }
}
