#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
workspace_root="${SHARED_WORKSPACE_ROOT:-$repo_root}"

repos=(
  code-intel-rust
  code-intel-ts
  context-mode-cli
  context-mode-mcp
  nixos-cli
  pi-context-mode
  pi-os-eco
  repo-map
)

for repo in "${repos[@]}"; do
  target="$workspace_root/$repo"
  echo "== $repo =="
  if [ ! -d "$target/.git" ]; then
    echo "missing"
    continue
  fi

  git -C "$target" status --short --branch
done
